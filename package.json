{
  "name": "ghostwrite",
  "private": true,
  "version": "0.0.0",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "node -e \"require(require('node:path').join(require('node:path').dirname(process.env.npm_package_json), 'scripts', 'dev.cjs'))\"",
    "dev:renderer:internal": "vite --strictPort --clearScreen false",
    "dev:electron:watch": "tsc -p tsconfig.electron.json --watch --preserveWatchOutput",
    "dev:desktop": "wait-on http://localhost:5173 file:dist-electron/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev:web": "vite",
    "build": "tsc -b && npm run build:electron && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron ."
  },
  "dependencies": {
    "diff": "^8.0.4",
    "electron": "^41.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  }
}
